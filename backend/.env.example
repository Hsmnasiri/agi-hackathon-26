# Copy to .env and fill in. With NO key set, the backend runs in OFFLINE mode
# (deterministic local fallbacks for extraction + explanation) — great for demos
# and for the frontend team to integrate against without credentials.

# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Force offline/deterministic mode even if a key is present:
# USE_MOCK_LLM=true

# Pipeline tuning
CONFIDENCE_THRESHOLD=0.7
EXTRACTION_TEMPERATURE=0
EXPLANATION_TEMPERATURE=0.3

# Comma-separated allowed origins for the frontend, or * for all.
CORS_ORIGINS=*

# Path to the provider directory.
PROVIDERS_PATH=providers.json
